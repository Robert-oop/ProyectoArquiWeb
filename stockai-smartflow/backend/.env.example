# ── App ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ── PostgreSQL ───────────────────────────────────────
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_USER=stockai_user
POSTGRES_PASSWORD=stockai_pass
POSTGRES_DB=stockai_db

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_32CHARS_MIN_PRODUCTION_KEY
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_32CHARS_KEY

# ── Rate limiting ─────────────────────────────────────
RATE_LIMIT=100
RATE_LIMIT_AUTH=10

# ── CORS ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# ── AI Service ───────────────────────────────────────
AI_SERVICE_URL=http://ai-service:9000
CV_CONFIDENCE_THRESHOLD=0.85
