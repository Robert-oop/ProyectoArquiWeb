      LEFT JOIN batches b ON p.id = b.product_id
        AND b.deleted_at IS NULL
        AND b.status = 'ACTIVE'
      WHERE p.deleted_at IS NULL
        AND p.is_active = true
      GROUP BY p.id, t.id
      HAVING COALESCE(SUM(b.quantity), 0) <= t.critical_stock
      ORDER BY p.name ASC
      LIMIT 25 OFFSET 0
