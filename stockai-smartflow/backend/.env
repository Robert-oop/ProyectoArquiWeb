# ── App ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ── PostgreSQL ───────────────────────────────────────
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_USER=stockai_user
POSTGRES_PASSWORD=stockai_pass
POSTGRES_DB=stockai_db

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=stockai_jwt_secret_dev_key_min32characters_ok
JWT_REFRESH_SECRET=stockai_refresh_secret_dev_key_min32chars

# ── Rate limiting ─────────────────────────────────────
RATE_LIMIT=100
RATE_LIMIT_AUTH=10

# ── CORS ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000

# ── AI Service ───────────────────────────────────────
AI_SERVICE_URL=http://ai-service:9000
CV_CONFIDENCE_THRESHOLD=0.85
AI_TIMEOUT_MS=10000

# ── Email / SMTP ──────────────────────────────────────
# Gmail: habilita 2FA en tu cuenta y genera una "Contraseña de aplicación"
#   Google Account → Seguridad → Contraseñas de aplicación
# Rellena las 4 variables con tus datos reales para activar el envío.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=rvillalobosbragado@gmail.com
SMTP_PASS=ytillccomhrsbkuc
SMTP_FROM="StockAI SmartFlow <rvillalobosbragado@gmail.com>"
