{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend — Node.js",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/backend/server.js",
      "envFile": "${workspaceFolder}/backend/.env",
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "restart": true,
      "runtimeExecutable": "nodemon"
    },
    {
      "name": "AI Service — Python",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--host", "0.0.0.0", "--port", "9000", "--reload"],
      "cwd": "${workspaceFolder}/ai-service",
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (Backend + AI)",
      "configurations": ["Backend — Node.js", "AI Service — Python"]
    }
  ]
}